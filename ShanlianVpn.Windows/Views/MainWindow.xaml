<Window x:Class="ShanlianVpn.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="闪连 VPN"
        Icon="/Assets/app-icon.ico"
        Width="980"
        Height="660"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#1C2A42"
                BorderThickness="0,0,1,0"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,28">
                        <Border Width="48"
                                Height="48"
                                CornerRadius="8"
                                Background="White"
                                Padding="0"
                                ClipToBounds="True">
                            <Image Source="/Assets/app-logo.png"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="闪连 VPN"
                                       Foreground="{StaticResource BrightTextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="安全全球网络"
                                       Foreground="{StaticResource SoftTextBrush}"
                                       FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="HomeNavButton"
                            Content="首页"
                            Click="HomeNav_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="NodesNavButton"
                            Content="节点"
                            Click="NodesNav_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="SubscriptionNavButton"
                            Content="订阅"
                            Click="SubscriptionNav_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="AccountNavButton"
                            Content="账户"
                            Click="AccountNav_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="SettingsNavButton"
                            Content="设置"
                            Click="SettingsNav_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="DiagnosticsNavButton"
                            Content="诊断"
                            Click="DiagnosticsNav_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="#101B2F"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="账户"
                                   Foreground="{StaticResource SoftTextBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="已登录"
                                   Foreground="{StaticResource BrightTextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,5,0,12"/>
                        <TextBlock Text="版本 1.0"
                                   Foreground="{StaticResource SoftTextBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="34,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="控制台"
                               Foreground="{StaticResource BrightTextBrush}"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="一键连接已验证稳定的 Profile B 线路。"
                               Foreground="{StaticResource SoftTextBrush}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#15243C"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="0">
                    <TextBlock x:Name="TopStatusTextBlock"
                               Text="未连接"
                               Style="{StaticResource StatusPillStyle}"/>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Frame x:Name="ContentFrame"
                       NavigationUIVisibility="Hidden"
                       Visibility="Collapsed"
                       Background="{StaticResource AppBackgroundBrush}"/>

                <Grid x:Name="HomePanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="0.75*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            Margin="0,0,22,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="连接状态"
                                           Foreground="{StaticResource SoftTextBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="StatusTextBlock"
                                           Text="未连接"
                                           Foreground="{StaticResource BrightTextBrush}"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"/>
                                <TextBlock x:Name="MessageTextBlock"
                                           Text="Network ready"
                                           Foreground="{StaticResource SoftTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button x:Name="CircleButton"
                                        Width="190"
                                        Height="190"
                                        BorderThickness="0"
                                        Background="{StaticResource AccentBrush}"
                                        Foreground="White"
                                        FontSize="22"
                                        FontWeight="SemiBold"
                                        Click="ConnectButton_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse Fill="#1A3457"
                                                         Width="220"
                                                         Height="220"
                                                         Opacity="0.55"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                                <Ellipse Fill="{TemplateBinding Background}"
                                                         Width="{TemplateBinding Width}"
                                                         Height="{TemplateBinding Height}">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#58A6FF" BlurRadius="24" ShadowDepth="0" Opacity="0.38"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.92"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.65"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button x:Name="SecondaryConnectButton"
                                        Content="连接"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Width="220"
                                        Margin="0,26,0,0"
                                        Click="ConnectButton_Click"/>
                            </StackPanel>

                            <Button x:Name="AdminRestartButton"
                                    Grid.Row="2"
                                    Content="以管理员身份重启"
                                    Visibility="Collapsed"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="{StaticResource WarningBrush}"
                                    Click="AdminRestartButton_Click"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="当前节点"
                                           Foreground="{StaticResource SoftTextBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="SelectedNodeTextBlock"
                                           Text="United States"
                                           Foreground="{StaticResource BrightTextBrush}"
                                           FontSize="23"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0"/>
                                <TextBlock Text="优先使用 Profile B"
                                           Foreground="{StaticResource SoftTextBrush}"
                                           Margin="0,6,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="国家/地区"
                                                   Foreground="{StaticResource SoftTextBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text="US"
                                                   Foreground="{StaticResource BrightTextBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="延迟"
                                                   Foreground="{StaticResource SoftTextBrush}"
                                                   FontSize="12"/>
                                        <TextBlock x:Name="LatencyTextBlock"
                                                   Text="-- ms"
                                                   Foreground="{StaticResource BrightTextBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <UniformGrid Columns="2" Rows="2">
                            <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,9,9">
                                <StackPanel>
                                    <TextBlock Text="TUN" Foreground="{StaticResource SoftTextBrush}" FontSize="12"/>
                                    <TextBlock x:Name="TunHealthTextBlock" Text="已准备" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="16" Margin="9,0,0,9">
                                <StackPanel>
                                    <TextBlock Text="路由" Foreground="{StaticResource SoftTextBrush}" FontSize="12"/>
                                    <TextBlock x:Name="RouteHealthTextBlock" Text="已准备" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,9,9,0">
                                <StackPanel>
                                    <TextBlock Text="DNS" Foreground="{StaticResource SoftTextBrush}" FontSize="12"/>
                                    <TextBlock x:Name="DnsHealthTextBlock" Text="已准备" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="16" Margin="9,9,0,0">
                                <StackPanel>
                                    <TextBlock Text="HTTPS" Foreground="{StaticResource SoftTextBrush}" FontSize="12"/>
                                    <TextBlock x:Name="HttpsHealthTextBlock" Text="已准备" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
