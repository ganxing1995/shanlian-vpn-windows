<Window x:Class="ShanlianVpn.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="闪连 VPN"
        Width="560"
        Height="720"
        MinWidth="500"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F6F8FB"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#EAECF0" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <TextBlock Text="闪连 VPN"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#101828"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TopStatusTextBlock"
                           Text="未连接"
                           Foreground="{StaticResource MutedTextBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Frame x:Name="ContentFrame"
                   NavigationUIVisibility="Hidden"
                   Visibility="Collapsed"/>

            <StackPanel x:Name="HomePanel"
                        Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button x:Name="CircleButton"
                        Width="190"
                        Height="190"
                        BorderThickness="0"
                        Background="{StaticResource BrandBrush}"
                        Foreground="White"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Click="ConnectButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="95"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock x:Name="StatusTextBlock"
                           Text="未连接"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#101828"
                           HorizontalAlignment="Center"
                           Margin="0,28,0,12"/>

                <TextBlock x:Name="MessageTextBlock"
                           Text="请选择线路后连接"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>

                <Button x:Name="AdminRestartButton"
                        Content="以管理员身份重启"
                        Visibility="Collapsed"
                        Margin="0,0,0,22"
                        Click="AdminRestartButton_Click"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="White" BorderBrush="#EAECF0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="当前线路" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                            <TextBlock x:Name="SelectedNodeTextBlock" Text="未选择" Foreground="#101828" FontSize="18" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" BorderBrush="#EAECF0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="延迟" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                            <TextBlock x:Name="LatencyTextBlock" Text="-- ms" Foreground="#101828" FontSize="18" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Button x:Name="SecondaryConnectButton"
                        Content="连接"
                        Background="{StaticResource BrandBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,10,0,0"
                        Click="ConnectButton_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#EAECF0" BorderThickness="0,1,0,0">
            <UniformGrid Columns="4" Margin="18,10">
                <Button Content="首页" Click="HomeNav_Click" Margin="4"/>
                <Button Content="线路" Click="NodesNav_Click" Margin="4"/>
                <Button Content="订阅" Click="SubscriptionNav_Click" Margin="4"/>
                <Button Content="我的" Click="AccountNav_Click" Margin="4"/>
            </UniformGrid>
        </Border>
    </Grid>
</Window>
