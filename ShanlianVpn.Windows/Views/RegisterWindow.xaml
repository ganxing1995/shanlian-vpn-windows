<Window x:Class="ShanlianVpn.Windows.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="娉ㄥ唽璐﹀彿"
        Width="400"
        Height="430"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Border Width="320"
            Padding="24"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
        <StackPanel>
            <TextBlock Text="娉ㄥ唽璐﹀彿"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrightTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,22"/>
            <TextBlock Text="閭" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="EmailTextBox"
                     Background="{DynamicResource PanelBrush}"
                     Foreground="{DynamicResource BrightTextBrush}"
                     BorderBrush="{DynamicResource CardBorderBrush}"
                     Margin="0,0,0,14"/>
            <TextBlock Text="瀵嗙爜" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox"
                         Background="{DynamicResource PanelBrush}"
                         Foreground="{DynamicResource BrightTextBrush}"
                         BorderBrush="{DynamicResource CardBorderBrush}"
                         Margin="0,0,0,18"/>
            <Button x:Name="RegisterButton"
                    Content="娉ㄥ唽"
                    Background="{StaticResource BrandBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="RegisterButton_Click"/>
            <TextBlock x:Name="MessageTextBlock"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0"/>
        </StackPanel>
    </Border>
</Window>

