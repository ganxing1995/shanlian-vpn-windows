<Window x:Class="ShanlianVpn.Windows.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册账号"
        Width="400"
        Height="430"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FB">
    <Border Width="320" Padding="24" Background="White" BorderBrush="#EAECF0" BorderThickness="1" CornerRadius="8"
            VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel>
            <TextBlock Text="注册账号" FontSize="24" FontWeight="SemiBold" Foreground="#101828" HorizontalAlignment="Center" Margin="0,0,0,22"/>
            <TextBlock Text="邮箱" Foreground="#344054" Margin="0,0,0,6"/>
            <TextBox x:Name="EmailTextBox" Margin="0,0,0,14"/>
            <TextBlock Text="密码" Foreground="#344054" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,18"/>
            <Button x:Name="RegisterButton" Content="注册" Background="{StaticResource BrandBrush}" Foreground="White" BorderThickness="0" Click="RegisterButton_Click"/>
            <TextBlock x:Name="MessageTextBlock" Foreground="#D92D20" TextWrapping="Wrap" Margin="0,16,0,0"/>
        </StackPanel>
    </Border>
</Window>

