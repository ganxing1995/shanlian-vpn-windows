<Page x:Class="ShanlianVpn.Windows.Views.SubscriptionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="订阅"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrightTextBrush}"/>
            <TextBlock Text="选择套餐后会在浏览器中打开安全支付页面。"
                       Foreground="{DynamicResource SoftTextBrush}"
                       Margin="0,6,0,22"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock x:Name="ExpiredTextBlock"
                               Text="订阅已过期，请续费后继续使用 VPN。"
                               Foreground="{StaticResource DangerBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"
                               Visibility="Collapsed"/>
                    <UniformGrid Columns="2" Rows="3">
                        <StackPanel Margin="0,0,18,16">
                            <TextBlock Text="当前套餐" Foreground="{DynamicResource SoftTextBrush}"/>
                            <TextBlock x:Name="PlanTextBlock" Foreground="{DynamicResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,16">
                            <TextBlock Text="状态" Foreground="{DynamicResource SoftTextBrush}"/>
                            <TextBlock x:Name="StatusTextBlock" Foreground="{DynamicResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,18,16">
                            <TextBlock Text="到期时间" Foreground="{DynamicResource SoftTextBrush}"/>
                            <TextBlock x:Name="ExpiresTextBlock" Foreground="{DynamicResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,16">
                            <TextBlock Text="剩余天数" Foreground="{DynamicResource SoftTextBrush}"/>
                            <TextBlock x:Name="DaysTextBlock" Foreground="{DynamicResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="可用设备" Foreground="{DynamicResource SoftTextBrush}"/>
                            <TextBlock x:Name="DeviceLimitTextBlock" Foreground="{DynamicResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,0">
                            <TextBlock Text="已绑定设备" Foreground="{DynamicResource SoftTextBrush}"/>
                            <TextBlock x:Name="BoundDevicesTextBlock" Foreground="{DynamicResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Button Content="刷新订阅状态"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="160"
                    HorizontalAlignment="Left"
                    Margin="0,14,0,0"
                    Click="RefreshButton_Click"/>

            <TextBlock Text="可选套餐"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrightTextBrush}"
                       Margin="0,24,0,12"/>
            <StackPanel x:Name="PlansStackPanel"/>

            <Border x:Name="OrderPanel"
                    Style="{StaticResource CardStyle}"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="订单已创建，可继续在浏览器中完成支付。"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrightTextBrush}"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="OrderNoTextBlock" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="OrderPlanTextBlock" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="OrderAmountTextBlock" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,12"/>
                    <Button x:Name="PayButton" Content="前往支付" Style="{StaticResource PrimaryButtonStyle}" Click="PayButton_Click"/>
                    <Button Content="刷新订阅状态"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,10,0,0"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

