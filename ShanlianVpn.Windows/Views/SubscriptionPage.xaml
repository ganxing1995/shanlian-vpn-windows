<Page x:Class="ShanlianVpn.Windows.Views.SubscriptionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="订阅"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrightTextBrush}"/>
            <TextBlock Text="查看套餐详情和续费选项。"
                       Foreground="{StaticResource SoftTextBrush}"
                       Margin="0,6,0,22"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock x:Name="ExpiredTextBlock"
                               Text="订阅已过期，请续费后继续使用 VPN。"
                               Foreground="{StaticResource DangerBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"
                               Visibility="Collapsed"/>
                    <UniformGrid Columns="2" Rows="3">
                        <StackPanel Margin="0,0,18,16">
                            <TextBlock Text="当前套餐" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="PlanTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,16">
                            <TextBlock Text="状态" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="StatusTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,18,16">
                            <TextBlock Text="到期时间" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="ExpiresTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,16">
                            <TextBlock Text="剩余天数" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="DaysTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="可用设备" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="DeviceLimitTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,0">
                            <TextBlock Text="已绑定设备" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="BoundDevicesTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <TextBlock Text="套餐"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrightTextBrush}"
                       Margin="0,24,0,12"/>
            <StackPanel x:Name="PlansStackPanel"/>

            <Border x:Name="OrderPanel"
                    Style="{StaticResource CardStyle}"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="订单已创建，请通过官方渠道完成付款。"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrightTextBrush}"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="OrderNoTextBlock" Foreground="{StaticResource SoftTextBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="OrderPlanTextBlock" Foreground="{StaticResource SoftTextBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="OrderAmountTextBlock" Foreground="{StaticResource SoftTextBrush}" Margin="0,0,0,12"/>
                    <Button x:Name="PayButton" Content="联系客服" Style="{StaticResource PrimaryButtonStyle}" Click="PayButton_Click"/>
                    <Button Content="刷新订阅"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#1E3354"
                            Margin="0,10,0,0"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
