<Page x:Class="ShanlianVpn.Windows.Views.SubscriptionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="Subscription"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrightTextBrush}"/>
            <TextBlock Text="Plan details and renewal options."
                       Foreground="{StaticResource SoftTextBrush}"
                       Margin="0,6,0,22"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock x:Name="ExpiredTextBlock"
                               Text="Subscription expired. Renew to continue using VPN."
                               Foreground="{StaticResource DangerBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"
                               Visibility="Collapsed"/>
                    <UniformGrid Columns="2" Rows="3">
                        <StackPanel Margin="0,0,18,16">
                            <TextBlock Text="Current plan" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="PlanTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,16">
                            <TextBlock Text="Status" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="StatusTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,18,16">
                            <TextBlock Text="Expires" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="ExpiresTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,16">
                            <TextBlock Text="Days left" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="DaysTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="Device limit" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="DeviceLimitTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="18,0,0,0">
                            <TextBlock Text="Bound devices" Foreground="{StaticResource SoftTextBrush}"/>
                            <TextBlock x:Name="BoundDevicesTextBlock" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <TextBlock Text="Plans"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrightTextBrush}"
                       Margin="0,24,0,12"/>
            <StackPanel x:Name="PlansStackPanel"/>

            <Border x:Name="OrderPanel"
                    Style="{StaticResource CardStyle}"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Order created. Complete payment through the official channel."
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrightTextBrush}"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="OrderNoTextBlock" Foreground="{StaticResource SoftTextBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="OrderPlanTextBlock" Foreground="{StaticResource SoftTextBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="OrderAmountTextBlock" Foreground="{StaticResource SoftTextBrush}" Margin="0,0,0,12"/>
                    <Button x:Name="PayButton" Content="Contact support" Style="{StaticResource PrimaryButtonStyle}" Click="PayButton_Click"/>
                    <Button Content="Refresh subscription"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#1E3354"
                            Margin="0,10,0,0"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
