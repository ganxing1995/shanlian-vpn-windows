<Page x:Class="ShanlianVpn.Windows.Views.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F6F8FB">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="我的"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#101828"
                       Margin="0,0,0,18"/>

            <Border Background="White" BorderBrush="#EAECF0" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="账号" Foreground="#667085"/>
                    <TextBlock x:Name="EmailTextBlock" FontSize="18" Foreground="#101828" Margin="0,8,0,20"/>

                    <TextBlock Text="我的设备" Foreground="#667085"/>
                    <TextBlock x:Name="DeviceTextBlock" FontSize="18" Foreground="#101828" Margin="0,8,0,20"/>

                    <TextBlock Text="联系客服" Foreground="#667085"/>
                    <TextBlock Text="请通过官方客服渠道联系支持" FontSize="16" Foreground="#101828" Margin="0,8,0,20"/>

                    <TextBlock Text="版本号" Foreground="#667085"/>
                    <TextBlock x:Name="VersionTextBlock" FontSize="16" Foreground="#101828" Margin="0,8,0,24"/>

                    <Button Content="退出登录" Click="LogoutButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
