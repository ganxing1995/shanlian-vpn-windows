<Page x:Class="ShanlianVpn.Windows.Views.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="Account"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrightTextBrush}"/>
            <TextBlock Text="Your login, devices, and safe support actions."
                       Foreground="{StaticResource SoftTextBrush}"
                       Margin="0,6,0,22"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Signed in as" Foreground="{StaticResource SoftTextBrush}"/>
                    <TextBlock x:Name="EmailTextBlock"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrightTextBrush}"
                               Margin="0,8,0,22"/>

                    <TextBlock x:Name="DeviceSummaryTextBlock"
                               Text="Devices"
                               Foreground="{StaticResource SoftTextBrush}"/>
                    <StackPanel x:Name="DevicesStackPanel" Margin="0,10,0,22"/>

                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#15243C" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Support" Foreground="{StaticResource SoftTextBrush}"/>
                                <TextBlock Text="Official customer service channel"
                                           Foreground="{StaticResource BrightTextBrush}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#15243C" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Version" Foreground="{StaticResource SoftTextBrush}"/>
                                <TextBlock x:Name="VersionTextBlock"
                                           Foreground="{StaticResource BrightTextBrush}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Button Content="Copy safe diagnostics"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,0,10"
                            Click="CopyDiagnosticsButton_Click"/>
                    <Button Content="Change password"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="#1E3354"
                            Margin="0,0,0,10"
                            Click="ChangePasswordButton_Click"/>
                    <Button Content="Sign out"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="{StaticResource DangerBrush}"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
