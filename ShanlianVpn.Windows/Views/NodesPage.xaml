<Page x:Class="ShanlianVpn.Windows.Views.NodesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <Grid Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="地区"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrightTextBrush}"/>
                    <TextBlock Text="按大区浏览节点，选择后应用会自动完成安全连接。"
                               Foreground="{DynamicResource SoftTextBrush}"
                               Margin="0,6,0,0"/>
                </StackPanel>
                <Button x:Name="RefreshButton"
                        Content="刷新节点"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="132"
                        Click="RefreshButton_Click"/>
            </Grid>

            <StackPanel x:Name="NodesStackPanel"/>
        </StackPanel>
    </ScrollViewer>
</Page>

