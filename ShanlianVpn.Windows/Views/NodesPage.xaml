<Page x:Class="ShanlianVpn.Windows.Views.NodesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F6F8FB">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="选择线路"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#101828"
                       Margin="0,0,0,18"/>
            <Button x:Name="RefreshButton"
                    Content="刷新线路和延迟"
                    Margin="0,0,0,16"
                    Click="RefreshButton_Click"/>
            <StackPanel x:Name="NodesStackPanel"/>
        </StackPanel>
    </ScrollViewer>
</Page>
