<Window x:Class="ShanlianVpn.Windows.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改密码"
        Width="420"
        Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Border Width="340"
            Padding="24"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
        <StackPanel>
            <TextBlock Text="修改密码"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrightTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,22"/>
            <TextBlock Text="当前密码" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="CurrentPasswordBox"
                         Background="{DynamicResource PanelBrush}"
                         Foreground="{DynamicResource BrightTextBrush}"
                         BorderBrush="{DynamicResource CardBorderBrush}"
                         Margin="0,0,0,14"/>
            <TextBlock Text="新密码" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="NewPasswordBox"
                         Background="{DynamicResource PanelBrush}"
                         Foreground="{DynamicResource BrightTextBrush}"
                         BorderBrush="{DynamicResource CardBorderBrush}"
                         Margin="0,0,0,14"/>
            <TextBlock Text="确认新密码" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="ConfirmPasswordBox"
                         Background="{DynamicResource PanelBrush}"
                         Foreground="{DynamicResource BrightTextBrush}"
                         BorderBrush="{DynamicResource CardBorderBrush}"
                         Margin="0,0,0,18"/>
            <Button x:Name="SubmitButton"
                    Content="确认修改"
                    Background="{StaticResource BrandBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="SubmitButton_Click"/>
            <TextBlock x:Name="MessageTextBlock"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0"/>
        </StackPanel>
    </Border>
</Window>
