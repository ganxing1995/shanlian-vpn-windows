<Window x:Class="ShanlianVpn.Windows.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改密码"
        Width="420"
        Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FB">
    <Border Width="340"
            Padding="24"
            Background="White"
            BorderBrush="#EAECF0"
            BorderThickness="1"
            CornerRadius="8"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
        <StackPanel>
            <TextBlock Text="修改密码"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#101828"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,22"/>
            <TextBlock Text="当前密码" Foreground="#344054" Margin="0,0,0,6"/>
            <PasswordBox x:Name="CurrentPasswordBox" Margin="0,0,0,14"/>
            <TextBlock Text="新密码" Foreground="#344054" Margin="0,0,0,6"/>
            <PasswordBox x:Name="NewPasswordBox" Margin="0,0,0,14"/>
            <TextBlock Text="确认新密码" Foreground="#344054" Margin="0,0,0,6"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,18"/>
            <Button x:Name="SubmitButton"
                    Content="确认修改"
                    Background="{StaticResource BrandBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="SubmitButton_Click"/>
            <TextBlock x:Name="MessageTextBlock"
                       Foreground="#D92D20"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0"/>
        </StackPanel>
    </Border>
</Window>
