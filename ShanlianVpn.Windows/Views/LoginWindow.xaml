<Window x:Class="ShanlianVpn.Windows.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="闂繛 VPN"
        Width="420"
        Height="520"
        MinWidth="380"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid>
        <Border Width="340"
                Padding="28"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="闂繛 VPN"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource BrightTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <TextBlock Text="閭" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="EmailTextBox"
                         AutomationProperties.Name="閭"
                         Background="{DynamicResource PanelBrush}"
                         Foreground="{DynamicResource BrightTextBrush}"
                         BorderBrush="{DynamicResource CardBorderBrush}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="瀵嗙爜" Foreground="{DynamicResource SoftTextBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             AutomationProperties.Name="瀵嗙爜"
                             Background="{DynamicResource PanelBrush}"
                             Foreground="{DynamicResource BrightTextBrush}"
                             BorderBrush="{DynamicResource CardBorderBrush}"
                             Margin="0,0,0,22"/>

                <Button x:Name="LoginButton"
                        Content="鐧诲綍"
                        Background="{StaticResource BrandBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="LoginButton_Click"/>

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="娉ㄥ唽璐﹀彿" Margin="0,0,6,0" Click="RegisterButton_Click"/>
                    <Button Content="淇敼瀵嗙爜" Grid.Column="1" Margin="6,0,0,0" Click="ChangePasswordButton_Click"/>
                </Grid>

                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap"
                           Margin="0,18,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

