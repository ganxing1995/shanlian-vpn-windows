<Page x:Class="ShanlianVpn.Windows.Views.DiagnosticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="Diagnostics"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrightTextBrush}"/>
            <TextBlock Text="Safe connection summary without secrets."
                       Foreground="{StaticResource SoftTextBrush}"
                       Margin="0,6,0,22"/>

            <UniformGrid Columns="2" Rows="2" Margin="0,0,0,18">
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,9,9">
                    <StackPanel>
                        <TextBlock Text="TUN adapter" Foreground="{StaticResource SoftTextBrush}"/>
                        <TextBlock x:Name="TunTextBlock" Text="Ready" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="9,0,0,9">
                    <StackPanel>
                        <TextBlock Text="Route" Foreground="{StaticResource SoftTextBrush}"/>
                        <TextBlock x:Name="RouteTextBlock" Text="Ready" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,9,9,0">
                    <StackPanel>
                        <TextBlock Text="DNS" Foreground="{StaticResource SoftTextBrush}"/>
                        <TextBlock x:Name="DnsTextBlock" Text="Ready" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="9,9,0,0">
                    <StackPanel>
                        <TextBlock Text="HTTPS" Foreground="{StaticResource SoftTextBrush}"/>
                        <TextBlock x:Name="HttpsTextBlock" Text="Ready" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Safe summary"
                               Foreground="{StaticResource BrightTextBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <TextBox x:Name="SummaryTextBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="180"
                             Background="#0B1526"
                             Foreground="{StaticResource SoftTextBrush}"
                             BorderBrush="{StaticResource CardBorderBrush}"
                             BorderThickness="1"/>
                    <Button Content="Export diagnostics"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="180"
                            HorizontalAlignment="Left"
                            Margin="0,14,0,0"
                            Click="ExportButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
