<Page x:Class="ShanlianVpn.Windows.Views.DiagnosticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="高级诊断"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrightTextBrush}"/>
            <TextBlock Text="这些信息仅用于客服排查连接问题，日常使用时无需关注。"
                       Foreground="{StaticResource SoftTextBrush}"
                       Margin="0,6,0,22"/>

            <UniformGrid Columns="2" Rows="2" Margin="0,0,0,18">
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,9,9">
                    <StackPanel>
                        <TextBlock Text="安全通道 (TUN)" Foreground="{StaticResource SoftTextBrush}"/>
                        <TextBlock x:Name="TunTextBlock" Text="已准备" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="9,0,0,9">
                    <StackPanel>
                        <TextBlock Text="路由" Foreground="{StaticResource SoftTextBrush}"/>
                        <TextBlock x:Name="RouteTextBlock" Text="已准备" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,9,9,0">
                    <StackPanel>
                        <TextBlock Text="DNS" Foreground="{StaticResource SoftTextBrush}"/>
                        <TextBlock x:Name="DnsTextBlock" Text="已准备" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="9,9,0,0">
                    <StackPanel>
                        <TextBlock Text="HTTPS" Foreground="{StaticResource SoftTextBrush}"/>
                        <TextBlock x:Name="HttpsTextBlock" Text="已准备" Foreground="{StaticResource BrightTextBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="连接摘要"
                               Foreground="{StaticResource BrightTextBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <TextBox x:Name="SummaryTextBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="180"
                             Background="#0B1526"
                             Foreground="{StaticResource SoftTextBrush}"
                             BorderBrush="{StaticResource CardBorderBrush}"
                             BorderThickness="1"/>
                    <Button Content="复制诊断信息"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="180"
                            HorizontalAlignment="Left"
                            Margin="0,14,0,0"
                            Click="ExportButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
