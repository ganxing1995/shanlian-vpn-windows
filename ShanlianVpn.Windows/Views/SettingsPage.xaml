<Page x:Class="ShanlianVpn.Windows.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="设置"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrightTextBrush}"/>
            <TextBlock Text="选择适合你的连接方式和应用外观。"
                       Foreground="{DynamicResource SoftTextBrush}"
                       Margin="0,6,0,22"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="连接模式"
                               Foreground="{DynamicResource BrightTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="全局模式沿用当前稳定链路。极速模式会优先让常用本地网站直连，适合主动尝试。"
                               Foreground="{DynamicResource SoftTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,16"/>

                    <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <RadioButton x:Name="SpeedModeRadioButton"
                                         GroupName="ConnectionMode"
                                         Content="极速模式（推荐）"
                                         Checked="SpeedModeRadioButton_Checked"
                                         Foreground="{DynamicResource BrightTextBrush}"
                                         FontWeight="SemiBold"/>
                            <TextBlock Text="常用本地网站直连，需要安全访问的站点走 VPN，更快更省流量。"
                                       Foreground="{DynamicResource SoftTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="24,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <RadioButton x:Name="GlobalModeRadioButton"
                                         GroupName="ConnectionMode"
                                         Content="全局模式"
                                         Checked="GlobalModeRadioButton_Checked"
                                         Foreground="{DynamicResource BrightTextBrush}"
                                         FontWeight="SemiBold"/>
                            <TextBlock Text="所有网站和应用流量都通过 VPN，适合需要全程保护的场景。"
                                       Foreground="{DynamicResource SoftTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="24,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="主题"
                               Foreground="{DynamicResource BrightTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="切换浅色、深色或跟随系统外观。"
                               Foreground="{DynamicResource SoftTextBrush}"
                               Margin="0,6,0,16"/>

                    <UniformGrid Columns="3">
                        <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,8,0">
                            <RadioButton x:Name="DarkThemeRadioButton"
                                         GroupName="ThemeMode"
                                         Content="深色模式"
                                         Checked="DarkThemeRadioButton_Checked"
                                         Foreground="{DynamicResource BrightTextBrush}"
                                         FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="4,0">
                            <RadioButton x:Name="LightThemeRadioButton"
                                         GroupName="ThemeMode"
                                         Content="浅色模式"
                                         Checked="LightThemeRadioButton_Checked"
                                         Foreground="{DynamicResource BrightTextBrush}"
                                         FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8,0,0,0">
                            <RadioButton x:Name="SystemThemeRadioButton"
                                         GroupName="ThemeMode"
                                         Content="跟随系统"
                                         Checked="SystemThemeRadioButton_Checked"
                                         Foreground="{DynamicResource BrightTextBrush}"
                                         FontWeight="SemiBold"/>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="启动与连接"
                               Foreground="{DynamicResource BrightTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="这些选项会保存在本机，并在下次打开应用时继续生效。"
                               Foreground="{DynamicResource SoftTextBrush}"
                               Margin="0,6,0,16"/>

                    <CheckBox x:Name="LaunchOnStartupCheckBox"
                              Content="开机启动"
                              Checked="LaunchOnStartupCheckBox_Changed"
                              Unchecked="LaunchOnStartupCheckBox_Changed"
                              Foreground="{DynamicResource BrightTextBrush}"
                              Margin="0,0,0,12"/>
                    <CheckBox x:Name="AutoConnectCheckBox"
                              Content="打开应用后自动连接"
                              Checked="AutoConnectCheckBox_Changed"
                              Unchecked="AutoConnectCheckBox_Changed"
                              Foreground="{DynamicResource BrightTextBrush}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

