<Page x:Class="ShanlianVpn.Windows.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="设置"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrightTextBrush}"/>
            <TextBlock Text="安全的客户端偏好设置。高级 VPN 行为仍由已验证的连接流程管理。"
                       Foreground="{StaticResource SoftTextBrush}"
                       Margin="0,6,0,22"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="诊断日志"
                                       Foreground="{StaticResource BrightTextBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="安全日志已启用。敏感信息会被脱敏，不会在这里显示。"
                                       Foreground="{StaticResource SoftTextBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="#143A2A"
                                BorderBrush="#1F7A4A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="已启用"
                                       Foreground="#86EFAC"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="连接配置"
                                       Foreground="{StaticResource BrightTextBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Profile B 保持为优先使用的稳定 Windows 线路。"
                                       Foreground="{StaticResource SoftTextBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="#15243C"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="Profile B"
                                       Foreground="{StaticResource BrightTextBrush}"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
